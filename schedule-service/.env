# ─── Database ──────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@db:5432/schedule_db

# ─── App ───────────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
APP_ENV=production
DEBUG=false
LOG_LEVEL=INFO

# ─── Auth ──────────────────────────────────────────────────────────────
SUPABASE_JWT_SECRET=your-supabase-jwt-secret-here
SUPABASE_URL=https://your-project.supabase.co

# ─── CORS ──────────────────────────────────────────────────────────────
CORS_ORIGINS=*

# ─── Rate Limiting ─────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60

# ─── Schedule ──────────────────────────────────────────────────────────
MAX_PERIODS_PER_DAY=8
DAYS_PER_WEEK=5
